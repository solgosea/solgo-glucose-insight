<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/glance_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glance_widget_bg_dark">

    <TextView
        android:id="@+id/glance_accent"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:text=""
        android:background="#6EE89E" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="15dp"
        android:paddingTop="9dp"
        android:paddingEnd="13dp"
        android:paddingBottom="9dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/glance_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="--"
                android:textColor="#D6EDE3"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/glance_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:text="mmol/L"
                android:textColor="#8FBFAA"
                android:textSize="9.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/glance_trend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="&#8599;"
                android:textColor="#6EE89E"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/glance_delta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="+0.0"
                android:textColor="#6EE89E"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/glance_chart"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="7dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:src="@drawable/glance_widget_chart_dashboard" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:text=""
            android:background="#1F6EE89E" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIR 24H"
                    android:textColor="#4D7264"
                    android:textSize="7.5sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/glance_tir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#6EE89E"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/glance_link_glyph"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9679;"
                        android:textColor="#6EE89E"
                        android:textSize="8sp" />

                    <TextView
                        android:id="@+id/glance_source"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:ellipsize="end"
                        android:singleLine="true"
                        android:text="SolgoInsight"
                        android:textColor="#8FBFAA"
                        android:textSize="9.5sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/glance_freshness"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="Updated just now"
                    android:textColor="#4D7264"
                    android:textSize="8sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/glance_alt_value"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="--"
        android:visibility="gone" />
</FrameLayout>
