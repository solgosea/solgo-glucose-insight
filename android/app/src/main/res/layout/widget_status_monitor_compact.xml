<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/status_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/status_widget_bg_dark"
    android:padding="13dp">

    <TextView
        android:id="@+id/status_widget_accent"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:background="#6EE89E"
        android:text="" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="8dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/status_widget_mark"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="?"
                android:textColor="#6EE89E"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_widget_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:text="--"
                android:textColor="#6EE89E"
                android:textSize="26sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/status_widget_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Status unavailable"
            android:textColor="#8FBFAA"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/status_widget_state"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:text=""
            android:visibility="gone" />

        <TextView
            android:id="@+id/status_widget_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:text="Open SolgoInsight"
            android:textColor="#4D7264"
            android:textSize="8.5sp" />

        <TextView
            android:id="@+id/status_widget_updated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:fontFamily="monospace"
            android:maxLines="1"
            android:text="Not updated"
            android:textColor="#4D7264"
            android:textSize="8sp" />

        <LinearLayout
            android:id="@+id/status_widget_component_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/status_widget_component_1_glyph"
                android:layout_width="18dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="?"
                android:textColor="#6EE89E"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_widget_component_1_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Sensor"
                android:textColor="#D6EDE3"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_widget_component_1_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="--"
                android:textColor="#6EE89E"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_widget_component_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/status_widget_component_2_glyph"
                android:layout_width="18dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="?"
                android:textColor="#6EE89E"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_widget_component_2_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Uploader"
                android:textColor="#D6EDE3"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_widget_component_2_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="--"
                android:textColor="#6EE89E"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_widget_component_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/status_widget_component_3_glyph"
                android:layout_width="18dp"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="?"
                android:textColor="#6EE89E"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_widget_component_3_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Server"
                android:textColor="#D6EDE3"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/status_widget_component_3_level"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="--"
                android:textColor="#6EE89E"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/status_widget_component_1_detail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text=""
            android:visibility="gone" />

        <TextView
            android:id="@+id/status_widget_component_2_detail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text=""
            android:visibility="gone" />

        <TextView
            android:id="@+id/status_widget_component_3_detail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text=""
            android:visibility="gone" />

        <TextView
            android:id="@+id/status_widget_source"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:text=""
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
