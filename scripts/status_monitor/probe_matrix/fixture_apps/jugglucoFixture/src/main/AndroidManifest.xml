<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:theme="@style/ProbeFixtureTheme"
        android:label="Juggluco Probe Fixture"
        android:allowBackup="false"
        android:supportsRtl="true">
        <activity
            android:name=".ProbeFixtureActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <receiver
            android:name=".probe.JugglucoProbeFixtureReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.metaguru.probe.JUGGLUCO_SEND_GLUCOSE" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
